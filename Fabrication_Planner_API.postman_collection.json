		{
			"name": "Batches",
			"description": "Batch Generation and Batch History",
			"item": [
				{
					"name": "Generate Batch",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/batches/generate",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"batches",
								"generate"
							]
						},
						"description": "Core Business Logic: Generates a new fabrication batch.\n\nBehavior:\n1. Finds all spools with status PENDING or PENDING_MATERIAL\n2. Checks if ALL required materials are available in warehouse stock\n3. If sufficient → spool status becomes BATCHED, stock is deducted\n4. If insufficient → spool status becomes PENDING_MATERIAL\n5. Returns 201 CREATED if any spools were batched, 200 OK otherwise\n\nResponse includes:\n- batchedSpools: list of successfully batched spools\n- pendingSpools: list of spools that could not be batched (with shortage details)\n- batchedCount / pendingCount"
					}
				},
				{
					"name": "Get All Batches (Paginated)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/batches?page=0&size=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"batches"
							],
							"query": [
								{
									"key": "page",
									"value": "0"
								},
								{
									"key": "size",
									"value": "10"
								}
							]
						},
						"description": "Returns a paginated list of all generated batches with their spools."
					}
				},
				{
					"name": "Get Batch by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/batches/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"batches",
								"1"
							]
						},
						"description": "Returns a single batch by ID, including all spools in that batch."
					}
