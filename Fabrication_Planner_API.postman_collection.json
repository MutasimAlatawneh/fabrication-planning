	"item": [
		{
			"name": "Materials",
			"description": "CRUD operations for Warehouse Material Stock",
			"item": [
				{
					"name": "Get All Materials (Paginated)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/materials?page=0&size=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"materials"
							],
							"query": [
								{
									"key": "page",
									"value": "0",
									"description": "Page number (0-indexed)"
								},
								{
									"key": "size",
									"value": "10",
									"description": "Page size"
								}
							]
						},
						"description": "Returns a paginated list of all materials in the warehouse."
					}
				},
				{
					"name": "Search Materials",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/materials?page=0&size=10&search=PIPE",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"materials"
							],
							"query": [
								{
									"key": "page",
									"value": "0"
								},
								{
									"key": "size",
									"value": "10"
								},
								{
									"key": "search",
									"value": "PIPE",
									"description": "Search by code or description"
								}
							]
						},
						"description": "Search materials by code or description."
					}
				},
				{
					"name": "Get Material by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/materials/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"materials",
								"1"
							]
						},
						"description": "Returns a single material by its ID."
					}
				},
				{
					"name": "Create Material",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"code\": \"ELBOW-6IN\",\n    \"description\": \"6 inch 90° Elbow\",\n    \"quantity\": 30.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/materials",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"materials"
							]
						},
						"description": "Creates a new material in warehouse stock.\n\nValidation:\n- code: required, must be unique\n- description: required\n- quantity: required, >= 0"
					}
				},
				{
					"name": "Update Material",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"code\": \"ELBOW-6IN\",\n    \"description\": \"6 inch 90° Elbow (Updated)\",\n    \"quantity\": 50.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/materials/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"materials",
								"1"
							]
						},
						"description": "Updates an existing material by ID."
					}
				},
				{
					"name": "Delete Material",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/materials/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"materials",
								"1"
							]
						},
						"description": "Deletes a material by ID.\n\nNote: Will fail with 409 Conflict if the material is referenced by any spool_materials records."
					}
				}
			]
		},
